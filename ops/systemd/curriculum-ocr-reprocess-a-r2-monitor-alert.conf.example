# Install as ~/.config/bdfz/curriculum-ocr-monitor-alert.conf with mode 0600
# after replacing the monitor SHA with the exact sealed workspace digest.
# B-r3 is complete and disabled; this atomically rebinds the shared alert-only
# runtime to the sole live A-r2 lineage before the A-r2 timer is enabled.
BDFZ_OCR_ALERT_RUN_ROOT=/home/suen/curriculum-ocr-offload/runs/20260716T1520Z-partial14-reprocess
BDFZ_OCR_ALERT_LATEST_JSON=/home/suen/curriculum-ocr-offload/runs/20260716T1520Z-partial14-reprocess/monitor-a-r2/latest.json
BDFZ_OCR_ALERT_EXPECTED_RUN_ID=20260716T1520Z-partial14-reprocess
BDFZ_OCR_ALERT_WORKER_UNIT=curriculum-ocr-reprocess-a-r2.service
BDFZ_OCR_ALERT_MONITOR_SCRIPT=/home/suen/curriculum-ocr-offload/runs/20260716T1520Z-partial14-reprocess/workspace-a-r2/scripts/monitor-remote-ocr-single-shard.mjs
BDFZ_OCR_ALERT_MONITOR_SHA256=<LOWERCASE_64_HEX_SHA256>
