{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://curriculum.bdfz.net/schemas/page-evidence-reviewer-authorities-v1.json",
  "title": "Pinned page evidence reviewer authorities",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "policy", "reviewers"],
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": 1 },
    "policy": { "const": "pinned_ed25519_page_reviewers_v1" },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reviewer_id",
          "display_name",
          "status",
          "valid_from",
          "valid_until",
          "scopes",
          "public_key_pem"
        ],
        "properties": {
          "reviewer_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
          "display_name": { "type": "string", "minLength": 1 },
          "status": { "enum": ["active", "revoked"] },
          "valid_from": { "type": "string", "format": "date-time" },
          "valid_until": { "type": ["string", "null"], "format": "date-time" },
          "scopes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["page_display", "page_citation", "semantic_resolution"] }
          },
          "public_key_pem": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
