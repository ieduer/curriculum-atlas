{
  "name": "bdfz-curriculum-atlas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "面向教师的中国历年课程标准与考试评价演变证据图谱",
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "ops:ledger": "node scripts/build-project-operations-ledger.mjs",
    "catalog": "node scripts/build-catalog.mjs",
    "assets:audit": "node scripts/audit-project-assets.mjs",
    "assets:audit:downloads": "node scripts/audit-project-assets.mjs --downloads /Users/ylsuen/Downloads",
    "assets:receipt:downloads": "node scripts/build-downloads-asset-audit-receipt.mjs --downloads /Users/ylsuen/Downloads",
    "page-evidence:validate": "node scripts/page-evidence-release-hook.mjs --mode ordinary",
    "page-evidence:promotion:validate": "node scripts/page-evidence-release-hook.mjs --mode promotion",
    "release:manifest": "node scripts/prepare-release.mjs --output .wrangler/release-manifest.json",
    "release:evidence:preview": "node scripts/collect-release-environment-evidence.mjs --environment preview --output .wrangler/release-environment-evidence.json",
    "release:evidence:production": "node scripts/collect-release-environment-evidence.mjs --environment production --output .wrangler/release-environment-evidence.json",
    "sources:audit:moe-scans": "node scripts/audit-local-moe-scans.mjs",
    "sources:fetch": "node scripts/fetch-sources.mjs",
    "corpus:build": "node scripts/build-corpus.mjs",
    "corpus:private:build": "node scripts/build-private-corpus-bundle.mjs",
    "corpus:private:publish": "node scripts/publish-private-corpus-bundle.mjs",
    "corpus:private:hydrate": "node scripts/hydrate-corpus.mjs",
    "corpus:private:verify": "node scripts/verify-hydrated-corpus.mjs",
    "concepts:build": "node scripts/build-concept-evolution.mjs",
    "concepts:validate": "node scripts/validate-concept-evolution.mjs",
    "ontology:release:validate": "node scripts/validate-ontology-release.mjs",
    "compendium:boundaries:validate": "node scripts/validate-compendium-item-boundaries.mjs",
    "ocr:status": "node scripts/ocr-supervisor.mjs status",
    "ocr:audit:triangulate": "node scripts/build-ocr-triangulation-audit.mjs",
    "ocr:check": "node scripts/ocr-supervisor.mjs check",
    "ocr:once": "node scripts/ocr-supervisor.mjs once",
    "ocr:recover": "node scripts/ocr-supervisor.mjs recover --batch-pages 1 --force-immediate",
    "ocr:drain": "node scripts/ocr-supervisor.mjs drain",
    "ocr:watchdog": "node scripts/ocr-watchdog.mjs run",
    "ocr:watchdog:status": "node scripts/ocr-watchdog.mjs status",
    "corpus:import:preview": "node scripts/import-corpus.mjs --database bdfz-curriculum-atlas-preview --env preview --remote",
    "corpus:import:production": "node scripts/import-corpus.mjs --database bdfz-curriculum-atlas --remote",
    "metadata:publish:preview": "node scripts/publish-metadata.mjs --bucket bdfz-curriculum-atlas-sources-preview --remote --evidence .wrangler/release-environment-evidence.json",
    "metadata:publish:production": "node scripts/publish-metadata.mjs --bucket bdfz-curriculum-atlas-sources --remote --evidence .wrangler/release-environment-evidence.json",
    "metadata:publish:page-evidence:preview": "node scripts/publish-metadata.mjs --bucket bdfz-curriculum-atlas-sources-preview --remote --evidence .wrangler/release-environment-evidence.json --page-evidence-promotion",
    "metadata:publish:page-evidence:production": "node scripts/publish-metadata.mjs --bucket bdfz-curriculum-atlas-sources --remote --evidence .wrangler/release-environment-evidence.json --page-evidence-promotion",
    "metadata:rollback:preview": "node scripts/publish-metadata.mjs --bucket bdfz-curriculum-atlas-sources-preview --remote --evidence .wrangler/release-environment-evidence.json --rollback-pointer-receipt .wrangler/rollback-pointer-receipt.json",
    "metadata:rollback:production": "node scripts/publish-metadata.mjs --bucket bdfz-curriculum-atlas-sources --remote --evidence .wrangler/release-environment-evidence.json --rollback-pointer-receipt .wrangler/rollback-pointer-receipt.json",
    "check": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "test:python": "/Users/ylsuen/.venv/bin/python -m unittest tests/test_ocr_pdf_paddle.py",
    "verify": "npm run page-evidence:validate && npm run catalog && npm run assets:audit && npm run corpus:build && npm run compendium:boundaries:validate && npm run concepts:build && npm run concepts:validate && npm run ontology:release:validate && node scripts/validate-online-verification.mjs && npm run build && npm run check && npm test && npm run test:python && npm run release:manifest && wrangler deploy --dry-run --outdir .wrangler/dry-run && node scripts/assert-clean-release-source.mjs",
    "dev": "wrangler dev",
    "db:local": "wrangler d1 migrations apply bdfz-curriculum-atlas --local",
    "deploy:preview": "node scripts/deploy-worker.mjs --environment preview",
    "deploy:production": "node scripts/deploy-worker.mjs --environment production",
    "deploy:preview:ontology-promotion": "node scripts/deploy-worker.mjs --environment preview --ontology-promotion",
    "deploy:production:ontology-promotion": "node scripts/deploy-worker.mjs --environment production --ontology-promotion",
    "deploy:page-evidence:preview": "node scripts/deploy-worker.mjs --environment preview --page-evidence-promotion",
    "deploy:page-evidence:production": "node scripts/deploy-worker.mjs --environment production --page-evidence-promotion"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260715.1",
    "esbuild": "0.28.1",
    "miniflare": "4.20260708.1",
    "typescript": "^7.0.2",
    "wrangler": "^4.110.0"
  }
}
